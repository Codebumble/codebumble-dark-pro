{
    "name": "codebumble-dark-pro",
    "displayName": "Codebumble Dark Pro",
    "description": "Codebumble Dark Pro Theme for professional developers",
    "author": {
        "name": "Md. Saifur Rahman"
    },
    "keywords": [
        "codebumble",
        "dark",
        "pro",
        "theme",
        "italic",
        "dark theme",
        "stylish theme",
        "mordern",
        "theme",
        "cyberpunk",
        "cyber",
        "developer",
        "friendly",
        "best",
        "lite",
        "coder",
        "color",
        "black",
        "laravel",
        "env syntax",
        "syntax"
    ],
    "publisher": "Codebumble",
    "repository": {
        "type": "git",
        "url": "https://github.com/Code-Bumble/codebumble-dark-pro"
    },
    "icon": "codebumble-dark-pro.png",
    "version": "3.4.0",
    "engines": {
        "vscode": "^1.63.2"
    },
    "categories": [
        "Themes"
    ],
    "prettier": {
        "singleQuote": true,
        "semi": false
    },
    "extensionKind": [
        "ui",
        "workspace"
    ],
    "capabilities": {
        "untrustedWorkspaces": {
            "supported": true
        }
    },
    "contributes": {
        "themes": [
            {
                "label": "Codebumble Dark Pro",
                "uiTheme": "vs-dark",
                "path": "./themes/Codebumble Dark-color-theme.json"
            }
        ],
        "languages": [
            {
                "id": "blade",
                "aliases": [
                    "blade",
                    "blade"
                ],
                "extensions": [
                    ".blade.php"
                ],
                "configuration": "./laravel-conf.json"
            },
            {
                "id": "env",
                "aliases": [
                    "env",
                    "env"
                ],
                "extensions": [
                    ".env",
                    ".development",
                    ".local",
                    ".test",
                    ".production"
                ]
            }
        ],
        "grammars": [
            {
                "language": "blade",
                "scopeName": "text.html.php.blade",
                "path": "./syntaxes/blade.syntax.tmLanguage.json"
            },
            {
                "language": "env",
                "scopeName": ".env",
                "path": "./syntaxes/env.syntax.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "blade",
                "path": "./syntaxes/laravel.snippets.json"
            }
        ]
    },
    "dependencies": {
        "vsce": "^2.7.0"
    }
}
